{
  "name": "@signalsafe/simulator-theme-bootstrap",
  "version": "0.3.3",
  "type": "module",
  "description": "Bootstrap-token simulator theme for @signalsafe/simulator-device and @signalsafe/simulator-react semantic classes.",
  "license": "MIT",
  "sideEffects": ["*.css", "**/*.css"],
  "exports": {
    "./styles.css": "./styles.css"
  },
  "files": ["styles.css", "src/**/*.css", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "smoke:package": "node scripts/smoke-package.mjs",
    "publish:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "simulator",
    "theme",
    "css",
    "bootstrap",
    "signalsafe"
  ]
}
